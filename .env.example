# Gemini API key (required)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=0

# Vertex AI — required when using runner.py with persistent memory
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Agent Engine ID from your Vertex AI Reasoning Engine resource
# Create one at: https://console.cloud.google.com/vertex-ai/reasoning-engine
AGENT_ENGINE_ID=your-reasoning-engine-id

# Optional: identify the user for session/memory scoping
AGENT_USER_ID=default-user
